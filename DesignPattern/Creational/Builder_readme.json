Step 2 — Product Class
class HotelSearchRequest {
public:
    string location;
    string checkIn;
    string checkOut;
    int guests;
    int rooms;
    string currency;
    string filter;
    string sort;

    void print() {
        cout << location << " " << checkIn << " " << checkOut << endl;
    }
};
Step 3 — Builder Class
class HotelSearchRequestBuilder {
private:
    HotelSearchRequest req;

public:
    HotelSearchRequestBuilder& setLocation(string loc) {
        req.location = loc;
        return *this;
    }

    HotelSearchRequestBuilder& setCheckIn(string date) {
        req.checkIn = date;
        return *this;
    }

    HotelSearchRequestBuilder& setCheckOut(string date) {
        req.checkOut = date;
        return *this;
    }

    HotelSearchRequestBuilder& setGuests(int g) {
        req.guests = g;
        return *this;
    }

    HotelSearchRequestBuilder& setRooms(int r) {
        req.rooms = r;
        return *this;
    }

    HotelSearchRequestBuilder& setCurrency(string c) {
        req.currency = c;
        return *this;
    }

    HotelSearchRequestBuilder& setFilter(string f) {
        req.filter = f;
        return *this;
    }

    HotelSearchRequest build() {
        return req;
    }
};
Step 4 — Usage (Very important)
int main() {
    HotelSearchRequest request = HotelSearchRequestBuilder()
        .setLocation("Bangalore")
        .setCheckIn("2026-04-01")
        .setCheckOut("2026-04-05")
        .setGuests(2)
        .setRooms(1)
        .setCurrency("INR")
        .build();

    request.print();
}